# ── Email Alert Configuration ──
# Set EMAIL_ENABLED=true to activate email alerts for CRITICAL and HIGH severity articles.

EMAIL_ENABLED=false

# SMTP settings (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Where to send alerts
EMAIL_FROM="CyberSec Monitor <you@gmail.com>"
EMAIL_TO=alerts@yourcompany.com

# Minimum severity to trigger email: BREACH, CRITICAL, HIGH, or MEDIUM
# BREACH = data breaches/leaks (highest), CRITICAL = zero-days/ransomware/RCE
EMAIL_MIN_SEVERITY=BREACH

# ── Free Threat Intel API Keys (Optional) ──
# These are FREE community/personal API keys. Leave blank to disable.

# GreyNoise Community — free at https://viz.greynoise.io/signup
# Provides: internet noise/scan data, trending threat tags
GREYNOISE_API_KEY=

# VulnCheck Community — free at https://vulncheck.com/register
# Provides: KEV (Known Exploited Vulnerabilities), exploit intelligence
VULNCHECK_API_KEY=

# ThreatFox (abuse.ch) — no API key needed, always active
# Provides: recent IoCs (malware, C2, botnet indicators)

# ── Telegram (optional) ──
# Create a bot via @BotFather on Telegram (free), paste the token below.
# 12 channels are built-in with auto-rotation. Override with TELEGRAM_CHANNELS if needed.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNELS=vxunderground,DarkfeedNews,dailydarkweb   # optional override
