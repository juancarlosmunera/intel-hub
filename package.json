{
  "name": "cybersec-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c green,cyan \"node server.js\" \"vite --open\"",
    "start": "npm run build && npx pm2 start ecosystem.config.cjs --env production && node scripts/open-browser.js",
    "stop": "npx pm2 stop intel-hub",
    "restart": "npx pm2 restart intel-hub && node scripts/open-browser.js",
    "logs": "npx pm2 logs intel-hub",
    "status": "npx pm2 status",
    "server": "node server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.2",
    "pm2": "^6.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "rss-parser": "^3.13.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0"
  }
}
